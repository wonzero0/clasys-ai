  return (
    <View style={styles.screenPlaceholder}>
      <Text style={styles.screenTitle}>핏 랩</Text>
      <Text style={styles.screenSubtitle}>체형과 퍼스널 컬러를 간결하게 정리한 화면입니다.</Text>

      <View style={styles.sectionBlock}>
        <Text style={styles.sectionTitle}>체형 분석 요약</Text>
        <Text style={styles.sectionText}>A-line · 어깨선이 자연스럽게 보이는 실루엣이 잘 어울려요.</Text>
      </View>

      <View style={styles.sectionBlock}>
        <Text style={styles.sectionTitle}>퍼스널 컬러 요약</Text>
        <Text style={styles.sectionText}>Cool Summer · 네이비, 화이트, 차분한 그레이 계열이 잘 맞아요.</Text>
      </View>

      <View style={styles.sectionBlock}>
        <Text style={styles.sectionTitle}>코디 실패 방지 피드백</Text>
        <View style={styles.lineList}>
          <View style={styles.lineItem}>
            <Text style={styles.lineItemText}>너무 큰 오버핏 상의는 비율을 흐릴 수 있어요.</Text>
          </View>
          <View style={styles.lineItem}>
            <Text style={styles.lineItemText}>밝은 상의에는 톤 다운된 하의를 매치해보세요.</Text>
          </View>
          <View style={styles.lineItem}>
            <Text style={styles.lineItemText}>아우터는 어깨선이 자연스러운 디자인이 좋아요.</Text>
          </View>
        </View>
      </View>

      <View style={styles.sectionBlock}>
        <Text style={styles.sectionTitle}>스타일 성장률</Text>
        <Text style={styles.sectionText}>이번 달 코디 완성도 +8% · 지난달보다 더 안정적인 조합을 선택하고 있어요.</Text>
      </View>
    </View>
  )
}

