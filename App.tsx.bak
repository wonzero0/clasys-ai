function WardrobeScreen({
  onSelectClothes,
  showToast,
}: WardrobeScreenProps) {
  const [activeFilter, setActiveFilter] = useState<WardrobeFilter>('all')

  const items: WardrobeItem[] = [
    {
      id: 'navy-shirt',
      name: '네이비 셔츠',
      category: '상의',
      type: 'top',
      material: '옥스포드 코튼',
      lastWorn: '2026.04.20',
      utilization: '활용도 높음',
    },
    {
      id: 'white-tee',
      name: '화이트 티셔츠',
      category: '상의',
      type: 'top',
      material: '면 100%',
      lastWorn: '2026.03.28',
      utilization: '활용도 높음',
    },
    {
      id: 'blue-jeans',
      name: '청바지',
      category: '하의',
      type: 'bottom',
      material: '데님',
      lastWorn: '2026.04.03',
      utilization: '활용도 보통',
    },
    {
      id: 'leather-jacket',
      name: '레더 자켓',
      category: '아우터',
      type: 'outer',
      material: '합성가죽',
      lastWorn: '2026.01.18',
      utilization: '활용도 낮음',
      esgAlert: true,
    },
    {
      id: 'white-sneakers',
      name: '화이트 스니커즈',
      category: '신발',
      type: 'outer',
      material: '합성가죽',
      lastWorn: '2025.12.14',
      utilization: '활용도 낮음',
      esgAlert: true,
    },
  ]

  const filterTabs: Array<{ label: string; value: WardrobeFilter }> = [
    { label: '전체', value: 'all' },
    { label: '상의', value: 'top' },
    { label: '하의', value: 'bottom' },
    { label: '아우터', value: 'outer' },
    { label: '신발', value: 'shoes' },
  ]

  const filteredItems = items.filter((item) => {
    if (activeFilter === 'all') return true
    if (activeFilter === 'shoes') return item.category === '신발'
    return item.type === activeFilter
  })

  const handleSelectClothing = (item: WardrobeItem) => {
    const clothesData: Partial<SelectedClothes> = {}
    clothesData[item.type] = item.name
    onSelectClothes(clothesData)
    showToast('아바타에 적용했어요')
  }

  return (
    <View style={styles.wardrobeScreen}>
      <View style={styles.wardrobeHeader}>
        <View style={styles.wardrobeHeaderTop}>
          <View>
            <Text style={styles.screenTitle}>내 옷장</Text>
            <Text style={styles.screenSubtitle}>카테고리별로 가볍게 확인하고 바로 입어볼 수 있어요</Text>
          </View>
        </View>

        <View style={styles.wardrobeHeaderActionRow}>
          <Pressable
            style={({ pressed }) => [styles.minimalButton, pressed && styles.pressed]}
            onPress={() => showToast('사진 업로드 기능은 준비 중입니다')}
          >
            <Text style={styles.minimalButtonText}>+ 옷 사진 추가</Text>
          </Pressable>
        </View>

        <View style={styles.filterRow}>
          {filterTabs.map((tab) => {
            const isActive = activeFilter === tab.value
            return (
              <Pressable
                key={tab.value}
                style={({ pressed }) => [
                  styles.filterTab,
                  isActive && styles.filterTabActive,
                  pressed && styles.pressed,
                ]}
                onPress={() => setActiveFilter(tab.value)}
              >
                <Text style={[styles.filterTabText, isActive && styles.filterTabTextActive]}>
                  {tab.label}
                </Text>
              </Pressable>
            )
          })}
        </View>
      </View>

      <ScrollView showsVerticalScrollIndicator={false} contentContainerStyle={styles.wardrobeList}>
        {filteredItems.map((item) => (
          <Pressable
            key={item.id}
            style={({ pressed }) => [styles.wardrobeRow, pressed && styles.pressed]}
            onPress={() => handleSelectClothing(item)}
          >
            <View style={styles.wardrobeInfo}>
              <View style={styles.wardrobeNameRow}>
                <Text style={styles.wardrobeName}>{item.name}</Text>
                {item.esgAlert ? <Text style={styles.wardrobeBadge}>오랫동안 안 입었어요</Text> : null}
              </View>

              <Text style={styles.wardrobeMeta}>{item.category}</Text>
              <Text style={styles.wardrobeMeta}>소재 · {item.material}</Text>
              <Text style={styles.wardrobeMeta}>마지막 착용일 · {item.lastWorn}</Text>
              <Text style={styles.wardrobeMeta}>활용도 · {item.utilization}</Text>
            </View>

            <Text style={styles.wardrobeActionText}>입어보기</Text>
          </Pressable>
        ))}
      </ScrollView>
    </View>
  )
}

function FitLabScreen() {
  return (
    <View style={styles.screenPlaceholder}>
      <Text style={styles.screenTitle}>핏 랩</Text>
      <Text style={styles.screenSubtitle}>체형과 퍼스널 컬러를 간결하게 정리한 화면입니다.</Text>

      <View style={styles.sectionBlock}>
        <Text style={styles.sectionTitle}>체형 분석 요약</Text>
        <Text style={styles.sectionText}>A-line · 어깨선이 자연스럽게 보이는 실루엣이 잘 어울려요.</Text>
      </View>

      <View style={styles.sectionBlock}>
        <Text style={styles.sectionTitle}>퍼스널 컬러 요약</Text>
        <Text style={styles.sectionText}>Cool Summer · 네이비, 화이트, 차분한 그레이 계열이 잘 맞아요.</Text>
      </View>

      <View style={styles.sectionBlock}>
        <Text style={styles.sectionTitle}>코디 실패 방지 피드백</Text>
        <View style={styles.lineList}>
          <View style={styles.lineItem}>
            <Text style={styles.lineItemText}>너무 큰 오버핏 상의는 비율을 흐릴 수 있어요.</Text>
          </View>
          <View style={styles.lineItem}>
            <Text style={styles.lineItemText}>밝은 상의에는 톤 다운된 하의를 매치해보세요.</Text>
          </View>
          <View style={styles.lineItem}>
            <Text style={styles.lineItemText}>아우터는 어깨선이 자연스러운 디자인이 좋아요.</Text>
          </View>
        </View>
      </View>

      <View style={styles.sectionBlock}>
        <Text style={styles.sectionTitle}>스타일 성장률</Text>
        <Text style={styles.sectionText}>이번 달 코디 완성도 +8% · 지난달보다 더 안정적인 조합을 선택하고 있어요.</Text>
      </View>
    </View>
  )
}

function SocialScreen() {
  return (
    <View style={styles.screenPlaceholder}>
      <Text style={styles.screenTitle}>소셜</Text>
      <Text style={styles.screenSubtitle}>전체 피드와 친구 피드를 한 번에 확인할 수 있어요.</Text>

      <View style={styles.toggleRow}>
        <Pressable style={[styles.toggleChip, styles.toggleChipActive]}>
          <Text style={[styles.toggleChipText, styles.toggleChipTextActive]}>전체 피드</Text>
        </Pressable>
        <Pressable style={styles.toggleChip}>
          <Text style={styles.toggleChipText}>내 친구</Text>
        </Pressable>
      </View>

      <View style={styles.sectionBlock}>
        <Text style={styles.sectionTitle}>미니멀 코디 피드</Text>
        <View style={styles.lineList}>
          <View style={styles.feedItem}>
            <Text style={styles.feedTitle}>네이비 셋업</Text>
            <Text style={styles.feedText}>깔끔한 출근룩 · 저장 142</Text>
          </View>
          <View style={styles.feedItem}>
            <Text style={styles.feedTitle}>데일리 스트릿</Text>
