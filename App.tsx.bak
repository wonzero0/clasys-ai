}

function SettingsScreen() {
  return (
    <View style={styles.screenPlaceholder}>
      <Text style={styles.screenTitle}>설정</Text>
      <Text style={styles.screenSubtitle}>프로필과 스타일 데이터를 조용하고 깔끔하게 관리합니다.</Text>

      <View style={styles.sectionBlock}>
        <Text style={styles.sectionTitle}>프로필 정보</Text>
        <View style={styles.lineList}>
          <View style={styles.lineItem}>
            <Text style={styles.lineItemLabel}>이름</Text>
            <Text style={styles.lineItemValue}>user</Text>
          </View>
          <View style={styles.lineItem}>
            <Text style={styles.lineItemLabel}>지역</Text>
            <Text style={styles.lineItemValue}>서울</Text>
          </View>
          <View style={styles.lineItem}>
            <Text style={styles.lineItemLabel}>성별 / 연령대</Text>
            <Text style={styles.lineItemValue}>남성 · 20대 후반</Text>
          </View>
        </View>
      </View>

      <View style={styles.sectionBlock}>
        <Text style={styles.sectionTitle}>체형 / 컬러 수정</Text>
        <View style={styles.lineList}>
          <View style={styles.lineItem}>
            <Text style={styles.lineItemLabel}>체형 데이터 수정</Text>
            <Text style={styles.lineItemValue}>버튼</Text>
          </View>
          <View style={styles.lineItem}>
            <Text style={styles.lineItemLabel}>퍼스널 컬러 수정</Text>
            <Text style={styles.lineItemValue}>버튼</Text>
          </View>
        </View>
      </View>

      <View style={styles.sectionBlock}>
        <Text style={styles.sectionTitle}>개인정보 / 보안 설정</Text>
