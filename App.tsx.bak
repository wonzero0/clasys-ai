            <Text style={styles.feedText}>톤온톤 조합 · 저장 76</Text>
          </View>
        </View>
      </View>

      <View style={styles.sectionBlock}>
        <Pressable style={({ pressed }) => [styles.minimalButton, pressed && styles.pressed]}>
          <Text style={styles.minimalButtonText}>친구에게 코디 추천하기</Text>
        </Pressable>
      </View>
    </View>
  )
}

